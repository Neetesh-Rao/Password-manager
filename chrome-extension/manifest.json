{
  "manifest_version": 3,
  "name": "Vault Autofill",
  "version": "1.0",
  "description": "Securely autofill your passwords from Vault into any website.",
  "permissions": [
    "activeTab",
    "scripting",
    "cookies", 
    "storage"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://passwordvert.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "192": "icons/icon-192.png",
      "512": "icons/icon-512.png"
    }
  },
  "icons": {
    "192": "icons/icon-192.png",
    "512": "icons/icon-512.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/icon-192.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
